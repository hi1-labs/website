---
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import { FONTS_URL, SITE, SEO, THEME_STORAGE_KEY, LANG_STORAGE_KEY } from '@data/site';
import type { Locale } from '@i18n/config';
import { LOCALES, DEFAULT_LOCALE } from '@i18n/config';
import { getOgLocale, getCommonTranslations, stripLocalePrefix } from '@i18n/utils';
import '@styles/common.css';
import '@styles/components.css';

interface Props {
  title: string;
  description: string;
  lang: Locale;
  ogTitle?: string;
  ogDescription?: string;
  ogUrl?: string;
  ogImage?: string;
  navLinks: { label: string; href: string }[];
  footerLinks: { label: string; href: string }[];
  transparentNav?: boolean;
  variant?: 'default' | 'legal';
}

const {
  title,
  description,
  lang,
  ogTitle,
  ogDescription,
  ogUrl,
  ogImage,
  navLinks,
  footerLinks,
  transparentNav = false,
  variant = 'default',
} = Astro.props;

const ct = getCommonTranslations(lang);

const isLegal = variant === 'legal';
const pagePath = stripLocalePrefix(Astro.url.pathname);
const canonicalUrl = new URL(`/${lang}${pagePath || '/'}`, SITE.url).href;
const resolvedOgTitle = ogTitle || title;
const resolvedOgDescription = ogDescription || description;
const resolvedOgUrl = ogUrl || canonicalUrl;
const resolvedOgImage = ogImage || SEO.defaultOgImage;
const ogLocale = getOgLocale(lang);
const themeKey = THEME_STORAGE_KEY;
const langKey = LANG_STORAGE_KEY;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {LOCALES.map((locale) => (
      <link rel="alternate" hreflang={locale} href={new URL(`/${locale}${pagePath || '/'}`, SITE.url).href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(`/${DEFAULT_LOCALE}${pagePath || '/'}`, SITE.url).href} />
    <meta name="theme-color" content={SEO.themeColor} media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1a2e" media="(prefers-color-scheme: dark)" />
    <meta name="format-detection" content="telephone=no" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:url" content={resolvedOgUrl} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={SEO.twitterHandle} />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={FONTS_URL} rel="stylesheet" />
    <script is:inline define:vars={{ themeKey, langKey }}>
      (function () {
        var t = localStorage.getItem(themeKey);
        if (!t) t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', t);
        var lang = document.documentElement.lang;
        if (lang) localStorage.setItem(langKey, lang);
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">{ct.skipToContent}</a>
    <Nav
      links={navLinks}
      transparent={transparentNav}
      lang={lang}
      themeToggleLabel={ct.theme.toggleLabel}
      langSwitcherLabel={ct.langSwitcher.switchTo}
      mainNavLabel={ct.nav.mainNavLabel}
      homeLabel={ct.nav.homeLabel}
      menuToggleLabel={ct.nav.menuToggleLabel}
    />
    <main id="main-content" class={isLegal ? 'legal' : undefined}>
      <slot />
    </main>
    <Footer links={footerLinks} lang={lang} allRightsReserved={ct.footer.allRightsReserved} navigationLabel={ct.footer.navigationLabel} />
    {!isLegal && <script src="../scripts/animations.ts"></script>}
  </body>
</html>
