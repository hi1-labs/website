---
interface Props {
  tags: string[];
  class?: string;
  style?: string;
}

const { tags, class: className, style } = Astro.props;
const checkmarkSvg = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
---

<div class={`marquee${className ? ` ${className}` : ''}`} style={style}>
  <div class="marquee-track">
    {tags.map((tag) => (
      <span class="marquee-tag"><Fragment set:html={checkmarkSvg} />{tag}</span>
    ))}
    {/* Duplicate for seamless loop */}
    {tags.map((tag) => (
      <span class="marquee-tag"><Fragment set:html={checkmarkSvg} />{tag}</span>
    ))}
  </div>
</div>
