---
import { ICON_CHECKMARK } from '@data/icons';

interface Props {
  tags: string[];
  class?: string;
  style?: string;
}

const { tags, class: className, style } = Astro.props;
---

<div class={`marquee${className ? ` ${className}` : ''}`} style={style} aria-hidden="true">
  <div class="marquee-track">
    {tags.map((tag) => (
      <span class="marquee-tag"><Fragment set:html={ICON_CHECKMARK} />{tag}</span>
    ))}
    {/* Duplicate for seamless loop */}
    {tags.map((tag) => (
      <span class="marquee-tag"><Fragment set:html={ICON_CHECKMARK} />{tag}</span>
    ))}
  </div>
</div>
