---
import { ICON_APPLE, ICON_GOOGLE_PLAY } from '@data/icons';

interface Props {
  appStoreUrl: string;
  googlePlayUrl: string;
  appStoreLabel?: string;
  appStoreName?: string;
  googlePlayLabel?: string;
  googlePlayName?: string;
}

const {
  appStoreUrl,
  googlePlayUrl,
  appStoreLabel = 'Download on the',
  appStoreName = 'App Store',
  googlePlayLabel = 'Get it on',
  googlePlayName = 'Google Play',
} = Astro.props;
---

<div class="store-badges animate-on-scroll" style="--delay: 0.2s">
  <a href={appStoreUrl} target="_blank" rel="noopener" class="store-badge" data-platform="ios">
    <Fragment set:html={ICON_APPLE} />
    <div class="store-badge-text">
      <span class="store-badge-label">{appStoreLabel}</span>
      <span class="store-badge-store">{appStoreName}</span>
    </div>
  </a>
  <a href={googlePlayUrl} target="_blank" rel="noopener" class="store-badge" data-platform="android">
    <Fragment set:html={ICON_GOOGLE_PLAY} />
    <div class="store-badge-text">
      <span class="store-badge-label">{googlePlayLabel}</span>
      <span class="store-badge-store">{googlePlayName}</span>
    </div>
  </a>
</div>
