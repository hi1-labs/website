---
import ThemeToggle from '@components/ThemeToggle.astro';
import type { Locale } from '@i18n/config';
import { getLocalizedPath, getOtherLocales } from '@i18n/utils';

interface Props {
  links: { label: string; href: string }[];
  transparent?: boolean;
  lang: Locale;
  themeToggleLabel?: string;
  langSwitcherLabel?: string;
  mainNavLabel?: string;
  homeLabel?: string;
  menuToggleLabel?: string;
}

const {
  links,
  transparent = false,
  lang,
  themeToggleLabel = 'Toggle theme',
  langSwitcherLabel = 'Change language',
  mainNavLabel = 'Main navigation',
  homeLabel = 'hi1 labs home',
  menuToggleLabel = 'Toggle menu',
} = Astro.props;

const otherLocales = getOtherLocales(lang);
const langConfig: Record<Locale, { flag: string; label: string }> = {
  en: { flag: '🇺🇸', label: 'EN' },
  ru: { flag: '🇷🇺', label: 'RU' },
  kk: { flag: '🇰🇿', label: 'KK' },
  es: { flag: '🇪🇸', label: 'ES' },
  pt: { flag: '🇧🇷', label: 'PT' },
};
const currentLangConfig = langConfig[lang];
const currentPath = Astro.url.pathname;
---

<nav class={`nav${transparent ? ' nav-transparent' : ''}`} aria-label={mainNavLabel}>
  <a href={`/${lang}/`} class="nav-logo" aria-label={homeLabel}>
    <span class="logo-mark">h1</span>
  </a>

  <div id="nav-menu" class="nav-menu">
    {links.map((link) => (
      <a href={link.href}>{link.label}</a>
    ))}
  </div>

  <div class="nav-actions">
    <details class="lang-dropdown">
      <summary class="lang-switch" aria-label={langSwitcherLabel}>
        <span class="lang-flag">{currentLangConfig.flag}</span>
        <span class="lang-label">{currentLangConfig.label}</span>
      </summary>
      <div class="lang-dropdown-menu">
        {otherLocales.map((locale) => (
          <a href={getLocalizedPath(currentPath, locale)} class="lang-dropdown-item">
            <span class="lang-flag">{langConfig[locale].flag}</span>
            <span class="lang-label">{langConfig[locale].label}</span>
          </a>
        ))}
      </div>
    </details>
    <ThemeToggle label={themeToggleLabel} />
    <button
      id="menu-toggle"
      class="nav-burger"
      aria-label={menuToggleLabel}
      aria-expanded="false"
    >
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<script src="../scripts/nav.ts"></script>
