---
interface Props {
  iconSvg: string;
  title: string;
  description: string;
  delay?: string;
  variant?: 'default' | 'feature';
}

const { iconSvg, title, description, delay = '0s', variant = 'default' } = Astro.props;
---

<div class={`icon-card${variant === 'feature' ? ' icon-card--feature' : ''} animate-on-scroll`} style={`--delay: ${delay}`}>
  <div class="icon-card-icon">
    <Fragment set:html={iconSvg} />
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
</div>
