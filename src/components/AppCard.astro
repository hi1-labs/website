---
interface Props {
  href?: string;
  icon: string;
  title: string;
  tagline: string;
  badge?: string;
}

const { href, icon, title, tagline, badge } = Astro.props;
const Tag = href ? 'a' : 'div';
const linkProps = href ? { href } : {};
const disabledClass = href ? '' : ' app-card--disabled';
---

<Tag {...linkProps} class={`app-card${disabledClass}`}>
  <div class="app-card-icon">
    <div class="app-card-icon-placeholder">{icon}</div>
  </div>
  <h3>{title}</h3>
  <p>{tagline}</p>
  {badge && <span class={`app-card-badge${!href ? ' app-card-badge--dev' : ''}`}>{badge}</span>}
</Tag>
