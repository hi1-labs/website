---
import BaseLayout from '@layouts/BaseLayout.astro';
import Marquee from '@components/Marquee.astro';
import SectionHeader from '@components/SectionHeader.astro';
import StoreBadges from '@components/StoreBadges.astro';
import IconCard from '@components/IconCard.astro';
import Carousel from '@components/Carousel.astro';
import DownloadBanner from '@components/DownloadBanner.astro';
import { appNavLinks, appFooterLinks } from '@data/navigation';
import { appMarqueeTags, features } from '@data/app';
import { SITE } from '@data/site';
import { ICON_EMAIL, ICON_SHIELD, ICON_DOCUMENT } from '@data/icons';
import '@styles/app.css';

const softwareAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'App Name',
  description: 'A clear, one-sentence description of what your app does and why it matters.',
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'iOS, Android',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
};
---

<BaseLayout
  title="App Name — hi1 labs"
  description="A clear, one-sentence description of what your app does and why it matters."
  ogTitle="App Name — hi1 labs"
  ogDescription="A clear, one-sentence description of what your app does and why it matters."
  ogUrl="https://hi1labs.com/myapp/"
  navLinks={appNavLinks}
  footerLinks={appFooterLinks}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(softwareAppSchema)} />
  </Fragment>
  <!-- App Hero -->
  <section class="app-hero">
    <div class="app-hero-content">
      <div class="app-icon animate-on-scroll">
        <div class="app-icon-placeholder">🎯</div>
      </div>

      <h1 class="animate-on-scroll" style="--delay: 0.1s">Your app <em>tagline</em> here</h1>
      <p class="app-hero-desc animate-on-scroll" style="--delay: 0.15s">
        A clear, one-sentence description of what your app does and why people will love it.
      </p>

      <StoreBadges
        appStoreUrl="https://apps.apple.com/app/idXXXXXXXXX"
        googlePlayUrl="https://play.google.com/store/apps/details?id=com.hi1labs.myapp"
      />

      <Marquee tags={appMarqueeTags} class="animate-on-scroll" style="--delay: 0.25s" />
    </div>
  </section>

  <!-- Screenshots -->
  <section class="screenshots section-alt">
    <div class="section-inner">
      <SectionHeader eyebrow="Preview" title="See it in action" />
    </div>
    <Carousel
      id="screenshots-carousel"
      ariaLabel="Screenshot navigation"
      prevLabel="Previous screenshot"
      nextLabel="Next screenshot"
    >
      <div class="screenshot-frame"><div class="screenshot-placeholder">Screenshot 1</div></div>
      <div class="screenshot-frame"><div class="screenshot-placeholder">Screenshot 2</div></div>
      <div class="screenshot-frame"><div class="screenshot-placeholder">Screenshot 3</div></div>
      <div class="screenshot-frame"><div class="screenshot-placeholder">Screenshot 4</div></div>
      <div class="screenshot-frame"><div class="screenshot-placeholder">Screenshot 5</div></div>
    </Carousel>
  </section>

  <!-- Features -->
  <section class="section" id="features">
    <div class="section-inner">
      <SectionHeader
        eyebrow="Features"
        title="Everything you need, nothing you don't"
      />

      <div class="features-grid">
        {features.map((feature) => (
          <IconCard
            iconSvg={feature.iconSvg}
            title={feature.title}
            description={feature.description}
            delay={feature.delay}
            variant="feature"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Support -->
  <section class="section section-alt" id="support">
    <div class="section-inner">
      <div class="support-card animate-on-scroll">
        <h3>Need help?</h3>
        <p>We're here for you — reach out and we'll get back to you as soon as we can</p>

        <div class="support-links">
          <a href={`mailto:${SITE.supportEmail}`} class="support-link">
            <Fragment set:html={ICON_EMAIL} />
            {SITE.supportEmail}
          </a>
          <a href="/privacy" class="support-link">
            <Fragment set:html={ICON_SHIELD} />
            Privacy Policy
          </a>
          <a href="/terms" class="support-link">
            <Fragment set:html={ICON_DOCUMENT} />
            Terms of Service
          </a>
        </div>
      </div>
    </div>
  </section>

  <DownloadBanner
    appName="App Name"
    appStoreUrl="https://apps.apple.com/app/idXXXXXXXXX"
    googlePlayUrl="https://play.google.com/store/apps/details?id=com.hi1labs.myapp"
  />
</BaseLayout>

<script>
  import { initCarousel } from '../scripts/carousel';
  import { initDownloadBanner } from '../scripts/download-banner';
  import { initStoreBadges } from '../scripts/store-badges';

  initCarousel({
    carouselId: 'screenshots-carousel',
    trackSelector: '.carousel-track',
    itemSelector: '.screenshot-frame',
  });

  initDownloadBanner();
  initStoreBadges();
</script>
