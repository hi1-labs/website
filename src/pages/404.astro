---
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import { FONTS_URL, SITE, THEME_STORAGE_KEY, LANG_STORAGE_KEY } from '@data/site';
import { LOCALES, LANG_CONFIG, DEFAULT_LOCALE } from '@i18n/config';
import { getCommonTranslations } from '@i18n/utils';
import '@styles/common.css';
import '@styles/components.css';
import '@styles/404.css';

const defaultLocale = DEFAULT_LOCALE;
const defaultT = getCommonTranslations(DEFAULT_LOCALE);
const translations = Object.fromEntries(
  LOCALES.map((locale) => [locale, getCommonTranslations(locale)])
);
const locales = [...LOCALES];
const langConfig = { ...LANG_CONFIG };
const themeKey = THEME_STORAGE_KEY;
const langKey = LANG_STORAGE_KEY;
const siteName = SITE.name;
const siteYear = SITE.year;
---

<!doctype html>
<html lang={DEFAULT_LOCALE}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="robots" content="noindex" />
    <title id="page-title">{defaultT.notFound.title} — {SITE.name}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={FONTS_URL} rel="stylesheet" />
    <script is:inline define:vars={{ themeKey }}>
      (function () {
        var t = localStorage.getItem(themeKey);
        if (!t) t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
  </head>
  <body>
    <Nav
      links={[]}
      transparent={false}
      lang={DEFAULT_LOCALE}
      themeToggleLabel={defaultT.theme.toggleLabel}
      langSwitcherLabel={defaultT.langSwitcher.switchTo}
      mainNavLabel={defaultT.nav.mainNavLabel}
      homeLabel={defaultT.nav.homeLabel}
    />
    <main id="main-content" class="not-found">
      <p class="not-found-code">404</p>
      <h1 class="not-found-title" id="nf-heading">{defaultT.notFound.heading}</h1>
      <p class="not-found-desc" id="nf-desc">{defaultT.notFound.description}</p>
      <a href={`/${DEFAULT_LOCALE}/`} class="btn btn-primary" id="nf-link">{defaultT.notFound.backHome}</a>
    </main>
    <Footer links={[]} lang={DEFAULT_LOCALE} allRightsReserved={defaultT.footer.allRightsReserved} navigationLabel={defaultT.footer.navigationLabel} />
    <script is:inline define:vars={{ translations, locales, langKey, langConfig, siteName, siteYear, defaultLocale }}>
      (function () {
        var pathLang = window.location.pathname.split('/')[1];
        var lang = locales.indexOf(pathLang) !== -1 ? pathLang : '';
        if (!lang) {
          var saved = localStorage.getItem(langKey);
          if (saved && locales.indexOf(saved) !== -1) lang = saved;
        }
        if (!lang) {
          var nl = (navigator.language || '').toLowerCase();
          lang = locales.find(function (l) { return nl.startsWith(l); }) || defaultLocale;
        }
        var tr = translations[lang] || translations[defaultLocale];
        document.documentElement.lang = lang;

        /* Update 404 content */
        document.getElementById('page-title').textContent = tr.notFound.title + ' — ' + siteName;
        document.getElementById('nf-heading').textContent = tr.notFound.heading;
        document.getElementById('nf-desc').textContent = tr.notFound.description;
        var link = document.getElementById('nf-link');
        link.textContent = tr.notFound.backHome;
        link.href = '/' + lang + '/';

        /* Update nav */
        var navLogo = document.querySelector('.nav-logo');
        if (navLogo) {
          navLogo.href = '/' + lang + '/';
          navLogo.setAttribute('aria-label', tr.nav.homeLabel);
        }
        var navEl = document.querySelector('nav.nav');
        if (navEl) navEl.setAttribute('aria-label', tr.nav.mainNavLabel);

        /* Update lang switcher */
        var cur = langConfig[lang];
        if (cur) {
          var sf = document.querySelector('.lang-switch .lang-flag');
          var sl = document.querySelector('.lang-switch .lang-label');
          if (sf) sf.textContent = cur.flag;
          if (sl) sl.textContent = cur.label;
        }
        var langSwitch = document.querySelector('.lang-switch');
        if (langSwitch) langSwitch.setAttribute('aria-label', tr.langSwitcher.switchTo);

        /* Rebuild dropdown with other locales */
        var menu = document.querySelector('.lang-dropdown-menu');
        if (menu) {
          menu.innerHTML = '';
          locales.forEach(function (loc) {
            if (loc === lang) return;
            var a = document.createElement('a');
            a.href = '/' + loc + '/404';
            a.className = 'lang-dropdown-item';
            a.innerHTML = '<span class="lang-flag">' + langConfig[loc].flag + '</span><span class="lang-label">' + langConfig[loc].label + '</span>';
            menu.appendChild(a);
          });
        }

        /* Update theme toggle */
        var themeToggle = document.getElementById('theme-toggle');
        if (themeToggle) themeToggle.setAttribute('aria-label', tr.theme.toggleLabel);

        /* Update footer */
        var footerLogo = document.querySelector('.footer .logo-mark');
        if (footerLogo) footerLogo.href = '/' + lang + '/';
        var footerNav = document.querySelector('.footer-nav');
        if (footerNav) footerNav.setAttribute('aria-label', tr.footer.navigationLabel);
        var footerCopy = document.querySelector('.footer-copy');
        if (footerCopy) footerCopy.innerHTML = '&copy; ' + siteYear + ' ' + siteName + '. ' + tr.footer.allRightsReserved;
      })();
    </script>
  </body>
</html>
