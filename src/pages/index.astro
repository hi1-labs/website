// Accept-Language detection and redirects before this page is served.
// This page only appears in local dev or non-CF environments.
---
<!doctype html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>hi1 labs</title>
  <style>
    body { font-family: system-ui, sans-serif; display: flex; justify-content: center; align-items: center; min-height: 100vh; gap: 2rem; margin: 0; background: #000; color: #fff; }
    a { color: #0A84FF; font-size: 1.25rem; text-decoration: none; padding: 0.75rem 1.5rem; border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; }
    a:hover { background: rgba(10,132,255,0.1); }
  </style>
</head>
<body>
  <a href="/en/">🇺🇸 English</a>
  <a href="/ru/">🇷🇺 Русский</a>
  <a href="/kk/">🇰🇿 Қазақша</a>
</body>
</html>
