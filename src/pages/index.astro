---
// Root page: language selection fallback.
// On Cloudflare Pages, the edge Function (functions/index.ts) handles
// Accept-Language detection and redirects before this page is served.
// This page only appears in local dev or non-CF environments.
// The inline script auto-redirects based on navigator.language.
import { LANG_STORAGE_KEY } from '@data/site';
import { LOCALES, DEFAULT_LOCALE } from '@i18n/config';

const langKey = LANG_STORAGE_KEY;
const locales = [...LOCALES];
const defaultLocale = DEFAULT_LOCALE;
---
<!doctype html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>hi1 labs</title>
  <script is:inline define:vars={{ langKey, locales, defaultLocale }}>
    (function () {
      var saved = localStorage.getItem(langKey);
      if (saved && locales.indexOf(saved) !== -1) {
        window.location.replace('/' + saved + '/');
        return;
      }
      var nl = (navigator.language || '').toLowerCase();
      var target = locales.find(function (l) { return nl.startsWith(l); }) || defaultLocale;
      window.location.replace('/' + target + '/');
    })();
  </script>
</head>
<body></body>
</html>
