---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import Marquee from '@components/Marquee.astro';
import SectionHeader from '@components/SectionHeader.astro';
import StoreBadges from '@components/StoreBadges.astro';
import IconCard from '@components/IconCard.astro';
import Carousel from '@components/Carousel.astro';
import DownloadBanner from '@components/DownloadBanner.astro';
import { LOCALES, type Locale } from '@i18n/config';
import { getCommonTranslations, getAppTranslations } from '@i18n/utils';
import { SITE } from '@data/site';
import { ICON_EMAIL, ICON_SHIELD, ICON_DOCUMENT, ICON_STAR, ICON_LIGHTNING, ICON_MOON, ICON_PHONE, ICON_HEART } from '@data/icons';
import '@styles/app.css';

export const getStaticPaths: GetStaticPaths = () =>
  LOCALES.map((lang) => ({ params: { lang } }));

const lang = Astro.params.lang as Locale;
const t = getCommonTranslations(lang);
const appT = getAppTranslations(lang);

const navLinks = [
  { label: t.nav.allApps, href: `/${lang}/` },
  { label: t.nav.features, href: '#features' },
  { label: t.nav.support, href: '#support' },
];

const footerLinks = [
  { label: t.footer.home, href: `/${lang}/` },
  { label: t.footer.privacy, href: `/${lang}/privacy` },
  { label: t.footer.terms, href: `/${lang}/terms` },
];

const featureIcons = [ICON_STAR, ICON_SHIELD, ICON_LIGHTNING, ICON_MOON, ICON_PHONE, ICON_HEART];

const softwareAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: appT.schema.name,
  description: appT.schema.description,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'iOS, Android',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
};
---

<BaseLayout
  title={appT.meta.title}
  description={appT.meta.description}
  lang={lang}
  ogTitle={appT.meta.ogTitle}
  ogDescription={appT.meta.ogDescription}
  ogUrl={`${SITE.url}/${lang}/app/`}
  navLinks={navLinks}
  footerLinks={footerLinks}
  footerAllRightsReserved={t.footer.allRightsReserved}
  skipToContent={t.skipToContent}
  themeToggleLabel={t.theme.toggleLabel}
  langSwitcherLabel={t.langSwitcher.switchTo}
  mainNavLabel={t.nav.mainNavLabel}
  homeLabel={t.nav.homeLabel}
  menuToggleLabel={t.nav.menuToggleLabel}
  footerNavigationLabel={t.footer.navigationLabel}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(softwareAppSchema)} />
  </Fragment>
  <!-- App Hero -->
  <section class="app-hero">
    <div class="app-hero-content">
      <div class="app-icon animate-on-scroll">
        <div class="app-icon-placeholder">🎯</div>
      </div>

      <h1 class="animate-on-scroll" style="--delay: 0.1s">{appT.hero.tagline} <em>{appT.hero.taglineEmphasis}</em> {appT.hero.taglineSuffix}</h1>
      <p class="app-hero-desc animate-on-scroll" style="--delay: 0.15s">
        {appT.hero.description}
      </p>

      <StoreBadges
        appStoreUrl="https://apps.apple.com/app/idXXXXXXXXX"
        googlePlayUrl="https://play.google.com/store/apps/details?id=com.hi1labs.myapp"
        appStoreLabel={t.storeBadges.appStoreLabel}
        appStoreName={t.storeBadges.appStoreName}
        googlePlayLabel={t.storeBadges.googlePlayLabel}
        googlePlayName={t.storeBadges.googlePlayName}
      />

      <Marquee tags={appT.marqueeTags} class="animate-on-scroll" style="--delay: 0.25s" />
    </div>
  </section>

  <!-- Screenshots -->
  <section class="screenshots section-alt">
    <div class="section-inner">
      <SectionHeader eyebrow={appT.screenshots.eyebrow} title={appT.screenshots.title} />
    </div>
    <Carousel
      id="screenshots-carousel"
      ariaLabel={appT.carousel.label}
      prevLabel={appT.carousel.prevLabel}
      nextLabel={appT.carousel.nextLabel}
      slideLabel={t.carousel.goToSlide}
    >
      <div class="screenshot-frame"><div class="screenshot-placeholder">Screenshot 1</div></div>
      <div class="screenshot-frame"><div class="screenshot-placeholder">Screenshot 2</div></div>
      <div class="screenshot-frame"><div class="screenshot-placeholder">Screenshot 3</div></div>
      <div class="screenshot-frame"><div class="screenshot-placeholder">Screenshot 4</div></div>
      <div class="screenshot-frame"><div class="screenshot-placeholder">Screenshot 5</div></div>
    </Carousel>
  </section>

  <!-- Features -->
  <section class="section" id="features">
    <div class="section-inner">
      <SectionHeader
        eyebrow={appT.features.eyebrow}
        title={appT.features.title}
      />

      <div class="features-grid">
        {appT.featureItems.map((feature, i) => (
          <IconCard
            iconSvg={featureIcons[i]}
            title={feature.title}
            description={feature.description}
            delay={`${i * 0.05}s`}
            variant="feature"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Support -->
  <section class="section section-alt" id="support">
    <div class="section-inner">
      <div class="support-card animate-on-scroll">
        <h3>{appT.support.title}</h3>
        <p>{appT.support.description}</p>

        <div class="support-links">
          <a href={`mailto:${SITE.supportEmail}`} class="support-link">
            <Fragment set:html={ICON_EMAIL} />
            {SITE.supportEmail}
          </a>
          <a href={`/${lang}/privacy`} class="support-link">
            <Fragment set:html={ICON_SHIELD} />
            {appT.support.privacyPolicy}
          </a>
          <a href={`/${lang}/terms`} class="support-link">
            <Fragment set:html={ICON_DOCUMENT} />
            {appT.support.termsOfService}
          </a>
        </div>
      </div>
    </div>
  </section>

  <DownloadBanner
    appName={appT.downloadBanner.appName}
    appStoreUrl="https://apps.apple.com/app/idXXXXXXXXX"
    googlePlayUrl="https://play.google.com/store/apps/details?id=com.hi1labs.myapp"
  />
</BaseLayout>

<script>
  import { initCarousel } from '@scripts/carousel';
  import { initDownloadBanner } from '@scripts/download-banner';
  import { initStoreBadges } from '@scripts/store-badges';

  initCarousel({
    carouselId: 'screenshots-carousel',
    trackSelector: '.carousel-track',
    itemSelector: '.screenshot-frame',
  });

  initDownloadBanner();
  initStoreBadges();
</script>
